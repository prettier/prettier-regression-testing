{
  "name": "prettier-regression-testing",
  "private": true,
  "version": "1.0.0",
  "repository": "ssh://git@github.com/sosukesuzuki/prettier-regression-testing.git",
  "license": "MIT",
  "author": "sosukesuzuki <aosukeke@gmail.com>",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "fix": "prettier . --write && eslint . --fix",
    "lint": "run-p \"lint:*\"",
    "lint:eslint": "eslint",
    "lint:prettier": "prettier . --check",
    "lint:tsc": "tsc --noEmit",
    "test": "vitest",
    "execute": "node ./src/index.ts",
    "add-repository": "node scripts/add-repository.mjs",
    "update-repositories": "node scripts/update-repositories.mjs"
  },
  "dependencies": {
    "@actions/github": "9.1.1",
    "nano-spawn": "2.1.0",
    "node-style-text": "2.1.2",
    "outdent": "0.8.0",
    "pretty-ms": "9.3.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "25.9.2",
    "@typescript-eslint/eslint-plugin": "8.61.0",
    "@typescript-eslint/parser": "8.61.0",
    "eslint": "10.4.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-simple-import-sort": "13.0.0",
    "eslint-plugin-unicorn": "65.0.1",
    "globals": "17.6.0",
    "npm-run-all": "4.1.5",
    "prettier": "3.8.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.0",
    "vitest": "4.1.8"
  },
  "packageManager": "yarn@4.16.0"
}
